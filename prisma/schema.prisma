generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum HistoryType {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tasks        Task[]
  histories    TaskHistory[]
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    Priority
  status      TaskStatus
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  histories   TaskHistory[]

  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, dueDate])
}

model TaskHistory {
  id          String      @id @default(cuid())
  changeType  HistoryType
  description String
  createdAt   DateTime    @default(now())
  taskId      String
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}
